<div class="flex-fill wg-account-page">
	<section class="wg-account-panel mx-auto" aria-labelledby="wg-reset-title">
		<div class="wg-account-kicker">Account recovery</div>
		<h2 id="wg-reset-title" class="wg-account-title">Recover your Westgate account</h2>
		<p class="wg-account-copy">
			Password recovery is handled by the Westgate account system so the same credentials keep working for the forum and connected services.
		</p>

		<div class="wg-account-actions">
			<a class="btn btn-primary btn-lg" href="{config.westgateAccount.recoveryActionUrl}" target="_top" rel="nofollow">
				Start password recovery
			</a>
			<a class="btn btn-outline-secondary btn-lg" href="{config.westgateAccount.loginUrl}">
				Back to sign in
			</a>
		</div>

		<p class="wg-account-note">
			Recovery emails are sent from <span class="wg-account-code">noreply@westgate.pw</span>. Check spam or filters if the message does not arrive.
		</p>
	</section>
</div>
